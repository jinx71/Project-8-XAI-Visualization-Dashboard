# Leave MODEL_PATH empty to run in demo mode (ImageNet EfficientNetV2B0).
# Point it at your thesis Keras model to run the real 5-class classifier.
MODEL_PATH=
CLASS_NAMES=Dyskeratotic,Koilocytotic,Metaplastic,Parabasal,Superficial-Intermediate
INPUT_SIZE=224
# Optional: override GradCAM target layer (auto-detected if blank).
LAST_CONV_LAYER=
CORS_ORIGINS=http://localhost:5173
MAX_UPLOAD_MB=10
# Optional: enables Claude-generated clinical reports. Omit for template mode.
ANTHROPIC_API_KEY=
